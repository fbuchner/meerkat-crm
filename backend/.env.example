# Database Configuration
export SQLITE_DB_PATH='./static/meerkat.db'
# IMPORTANT: Must be an absolute path for security reaons (e.g., /var/data/meerkat/photos)
export PROFILE_PHOTO_DIR='/path/to/photos'

# Security
export JWT_SECRET_KEY='your-very-long-very-secret-jwt-key-change-this-in-production'
export JWT_EXPIRY_HOURS='96'

# Email notifications can be delivered via Resend, SMTP, or both. If both are set, every email is sent through both channels. Leave a section empty to disable that or both channels.

# Resend Email Configuration; https://resend.com/
export RESEND_API_KEY='YOUR_RESEND_API_KEY'
export RESEND_FROM_EMAIL='your-from-email@example.com'

# SMTP Email Configuration
# export SMTP_HOST='smtp.example.com'
# export SMTP_PORT='587'                 # default 587 (STARTTLS); use 465 with SMTP_USE_TLS=true
# export SMTP_USERNAME='your-username'   # optional; leave empty for unauthenticated relay
# export SMTP_PASSWORD='your-password'
# export SMTP_FROM_EMAIL='your-from-email@example.com'
# export SMTP_USE_TLS='false'            # true = implicit TLS (port 465); false = plaintext/STARTTLS

# Server Configuration (port is for backend, not frontend!)
export HOST_PORT='8080'
export TRUSTED_PROXIES=''

# Enable the CardDav server for contact sync (default is false)
export CARDDAV_ENABLED='true'

# Disable new user registration (default is false)
export DISABLE_REGISTRATION='false'

# Block webhook deliveries to private/loopback addresses (default is false), relevant for cloud or multi-tenant (prevent SSRF)
export WEBHOOK_BLOCK_PRIVATE_URLS='false'

# Reminder Configuration (HH:MM format, in the timezone specified below)
export REMINDER_TIME='06:00'
# Timezone for reminder scheduling. Must be a valid IANA timezone name.
export REMINDER_TIMEZONE='UTC'

# "*" works in dev with AllowOriginFunc, but specify exact URL in production
export FRONTEND_URL='*'

# HTTP Server Timeouts (in seconds)
export HTTP_READ_TIMEOUT='15'    # Maximum duration for reading the entire request
export HTTP_WRITE_TIMEOUT='15'   # Maximum duration for writing the response
export HTTP_IDLE_TIMEOUT='60'    # Maximum time to wait for the next request (keep-alive)

# Cookie Configuration
export COOKIE_SECURE='false'
export COOKIE_DOMAIN='localhost'
